    <xs:complexContent>
      <xs:extension base="D2LogicalModel:ParkingEquipmentOrServiceFacility">
        <xs:sequence>
          <xs:element name="equipmentType" type="D2LogicalModel:EquipmentTypeEnum" minOccurs="1" maxOccurs="1">
