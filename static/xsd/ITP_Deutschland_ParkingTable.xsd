  <xs:simpleType name="GroupOfParkingSitesTypeEnum">
    <xs:annotation>
      <xs:documentation>The type of this group of parking sites.</xs:documentation>
    </xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="truckParkingPriorityZone">
        <xs:annotation>
          <xs:documentation>This group is describing a truck parking priority zone according to the EU regulation.</xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="aggregationOfInformation">
