# PostgreSQL
POSTGRES_DB=rastmonitor
POSTGRES_USER=rastmonitor
POSTGRES_PASSWORD=changeme

# Mobilithek SID endpoints (DATEX II SOAP)
STATIC_ENDPOINT=https://mobilithek.info:8443/mobilithek/api/v1.0/subscription/1006362396091736064/clientPullService?subscriptionID=1006362396091736064
DYNAMIC_ENDPOINT=https://mobilithek.info:8443/mobilithek/api/v1.0/subscription/1006362327707783168/clientPullService?subscriptionID=1006362327707783168

# Absolute path on the HOST to the .p12 client certificate file.
# Must be absolute — Docker Compose does not resolve relative paths here.
# Example: /Users/yourname/certs/client.p12
CERT_P12=/absolute/path/to/your/client.p12
P12_PASSWORD=yourp12password
#NEXT_PUBLIC_MAP_STYLE=https://sgx.geodatenzentrum.de/gdz_basemapde_vektor/styles/bm_web_col.json